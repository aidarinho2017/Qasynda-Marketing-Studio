# App
APP_NAME=Qasynda Marketing Studio
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database — Supabase connection pooler (pgBouncer, transaction mode, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres

# JWT — generate a long random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`)
JWT_SECRET=<REPLACE_WITH_LONG_RANDOM_STRING>
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Google OAuth 2.0 — Web application client ID
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com

# Supabase Storage (S3-compatible)
# Get these from: Supabase Dashboard → Storage → S3 Connection
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_S3_ENDPOINT=https://<PROJECT_REF>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_S3_ACCESS_KEY_ID=<s3-access-key>
SUPABASE_S3_SECRET_ACCESS_KEY=<s3-secret-key>
SUPABASE_BUCKET_UPLOADS=uploads
SUPABASE_BUCKET_GENERATIONS=generations

# Gemini / Google Gen AI — get an API key from https://aistudio.google.com/
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
